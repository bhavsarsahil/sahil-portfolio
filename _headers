# Netlify cache headers
# index.html — NEVER cache (user always gets latest code)
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# JS & CSS — cache 1 year (safe because we use ?v=X to bust when we update)
/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable
